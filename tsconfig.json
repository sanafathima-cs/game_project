{
  "compilerOptions": {
    "target":           "ESNext",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "strict":           true,
    "sourceMap":        true,
    "outDir":           "./dist",
    "rootDir":          "./src",
    "skipLibCheck":     true,
    "types":            ["vite/client"]
  },
  "include": ["src"]
}